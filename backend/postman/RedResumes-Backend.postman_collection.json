              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"resumeUrl\": \"https://example.com/resume.pdf\"\n}"
            },
            "url": "{{baseUrl}}/api/jobs/{{jobId}}/apply"
          }
        },
        {
          "name": "Save Job",
          "request": {
            "method": "POST",
