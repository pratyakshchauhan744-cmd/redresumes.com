generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

generator adminClient {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
  output        = "../../admin-panel/node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  candidate
  employer
  admin
  manager
  support
}

enum RemoteType {
  onsite
  hybrid
  remote
}

enum EmploymentType {
  full_time
  part_time
  contract
  internship
  freelance
}

enum ExperienceLevel {
  entry
  mid
  senior
  lead
}

enum JobSourceType {
  api
  direct
}

enum ApplicationStatus {
  submitted
  reviewing
  shortlisted
  rejected
  hired
}

enum SignInMethod {
  email_password
  google
}

model User {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  passwordHash  String
  role          UserRole       @default(candidate)
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  phone         String?
  location      String?
  bio           String?
  photoDataUrl  String?
  applications  Application[]
  savedJobs     SavedJob[]
  postedJobs    Job[]          @relation("EmployerJobs")
  companies     Company[]      @relation("EmployerCompany")
  refreshTokens RefreshToken[]
  signInEvents  SignInEvent[]
  resumes       Resume[]
  interviewSessions InterviewSession[]
  subscription  UserSubscription?
  credits       UserCredit?
  transactions  CreditTransaction[]
  adminAuditLogs AdminAuditLog[] @relation("AdminActor")
  signOutEvents  SignOutEvent[]
}

model Company {
  id          String   @id @default(cuid())
  name        String
  website     String?
  logoUrl     String?
  description String?
  location    String?
  ownerId     String?
  owner       User?    @relation("EmployerCompany", fields: [ownerId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  jobs        Job[]

  @@index([name])
}

model Job {
  id             String          @id @default(cuid())
  title          String
  description    String
  companyId      String
  company        Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  postedById     String?
  postedBy       User?           @relation("EmployerJobs", fields: [postedById], references: [id], onDelete: SetNull)
  city           String?
  state          String?
  country        String?
  remoteType     RemoteType      @default(onsite)
  employmentType EmploymentType  @default(full_time)
  experienceLevel ExperienceLevel @default(entry)
  salaryMin      Int?
  salaryMax      Int?
  currency       String?         @default("USD")
  sourceType     JobSourceType   @default(direct)
  externalId     String?
  applyUrl       String?
  originalJobUrl String?
  source         String?
  postedAt       DateTime        @default(now())
  dedupeHash     String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  applications   Application[]
  savedByUsers   SavedJob[]

  @@unique([dedupeHash])
  @@index([title])
  @@index([city, state, country])
  @@index([companyId])
  @@index([postedById])
}

model Application {
  id        String            @id @default(cuid())
  userId    String
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId     String
  job       Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  resumeUrl String?
  status    ApplicationStatus @default(submitted)
  appliedAt DateTime          @default(now())
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@unique([userId, jobId])
  @@index([jobId])
}

model SavedJob {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, jobId])
  @@index([jobId])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model SignInEvent {
  id        String       @id @default(cuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  method    SignInMethod
  ipAddress String?
  userAgent String?
  createdAt DateTime     @default(now())

  @@index([userId])
  @@index([method])
  @@index([createdAt])
}

model IngestionLog {
  id           String   @id @default(cuid())
  source       String
  fetchedCount Int      @default(0)
  insertedCount Int     @default(0)
  dedupedCount Int      @default(0)
  status       String
  createdAt    DateTime @default(now())
}

model Resume {
  id             String             @id @default(cuid())
  userId         String?
  user           User?              @relation(fields: [userId], references: [id], onDelete: Cascade)
  fileName       String
  fileUrl        String?            
  parsedData     Json?              
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  sessions       InterviewSession[]
}

model InterviewSession {
  id             String               @id @default(cuid())
  userId         String?
  user           User?                @relation(fields: [userId], references: [id], onDelete: Cascade)
  resumeId       String
  resume         Resume               @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  targetRole     String
  companyType    String
  difficulty     String
  interviewStyle String
  durationMins   Int
  jobDescription String?
  interviewerPersona String? @default("HR Recruiter")
  stressMode     Boolean? @default(false)
  status         String               @default("in_progress")
  creditUsed     Boolean              @default(false)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  questions      InterviewQuestion[]
  report         InterviewReport?
  analytics      AnalyticsEvent[]
}

model InterviewQuestion {
  id             String               @id @default(cuid())
  sessionId      String
  session        InterviewSession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  questionText   String
  questionType   String               
  contextRef     String?              
  orderIndex     Int
  createdAt      DateTime             @default(now())
  answer         InterviewAnswer?
}

model InterviewAnswer {
  id             String               @id @default(cuid())
  questionId     String               @unique
  question       InterviewQuestion    @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answerText     String
  durationSecs   Int?
  score          Float?
  feedback       Json?                
  createdAt      DateTime             @default(now())
}

model InterviewReport {
  id             String               @id @default(cuid())
  sessionId      String               @unique
  session        InterviewSession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  overallScore   Float
  categoryScores Json
  strengths      String[]
  weaknesses     String[]
  recommendations String[]
  
  // Voice Analytics
  speakingPace   Int?     @default(135)
  fillerWords    Int?     @default(0)
  voiceConfidence Int?    @default(80)

  createdAt      DateTime @default(now())
}

model SubscriptionPlan {
  id             String               @id @default(cuid())
  name           String               
  priceId        String               
  priceAmount    Int                  
  currency       String               @default("INR")
  features       Json
  subscriptions  UserSubscription[]
}

model UserSubscription {
  id             String               @id @default(cuid())
  userId         String               @unique
  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId         String
  plan           SubscriptionPlan     @relation(fields: [planId], references: [id])
  razorpaySubId  String?              
  status         String               
  currentPeriodEnd DateTime
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
}

model AnalyticsEvent {
  id             String               @id @default(cuid())
  userId         String?
  sessionId      String?
  session        InterviewSession?    @relation(fields: [sessionId], references: [id])
  eventType      String               
  metadata       Json?
  createdAt      DateTime             @default(now())
}

model UserCredit {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance   Int      @default(0)
  updatedAt DateTime @updatedAt
}

model CreditTransaction {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  packageName     String
  creditsAdded    Int
  paymentAmount   Float
  razorpayPaymentId String   @unique
  status          String
  createdAt       DateTime @default(now())
}

model PublicResume {
  id         String   @id
  slug       String
  templateId String   @map("template_id")
  resumeData Json     @map("resume_data")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @default(now()) @map("updated_at")

  @@map("public_resumes")
}

model AdminAuditLog {
  id          String   @id @default(cuid())
  actorId     String
  actor       User     @relation("AdminActor", fields: [actorId], references: [id], onDelete: Cascade)
  action      String   // e.g., "ADJUST_CREDITS", "CHANGE_ROLE", "UPDATE_SETTING"
  entityType  String   // e.g., "User", "UserCredit", "SystemSetting"
  entityId    String?  // Target record ID
  oldValue    Json?    // Pre-change state snapshot
  newValue    Json?    // Post-change state snapshot
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([actorId])
  @@index([action])
  @@index([createdAt])
}

model SystemSetting {
  key         String   @id
  value       String
  description String?
  updatedAt   DateTime @updatedAt
}

model SignOutEvent {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}


