# GEMINI_API_KEY: Required for Gemini AI API calls.
# Put your own key here in local development.
GEMINI_API_KEY=your_gemini_api_key_here

# APP_URL: The URL where this app is hosted.
APP_URL=http://localhost:3000

# Public site URL used for canonical links and sitemap hostname
VITE_SITE_URL=https://redresumes.com

# Optional: Add GA4 Measurement ID to enable analytics (example: G-XXXXXXX)
VITE_GA_MEASUREMENT_ID=
