{
  "info": {
    "_postman_id": "2a1607ef-61be-4ca4-8d4f-8d0acdfb9b33",
    "name": "RedResumes Backend API",
    "description": "Postman collection for RedResumes Node.js + PostgreSQL backend",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/health"
      }
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Candidate",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Candidate One\",\n  \"email\": \"candidate+new@example.com\",\n  \"password\": \"Password@123\",\n  \"role\": \"candidate\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/register"
          }
        },
        {
          "name": "Login Candidate",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"candidate@example.com\",\n  \"password\": \"Password@123\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.accessToken) pm.environment.set('accessToken', data.accessToken);",
                  "if (data.refreshToken) pm.environment.set('refreshToken', data.refreshToken);"
                ]
              }
            }
          ]
        },
        {
          "name": "Login Employer",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"employer@example.com\",\n  \"password\": \"Password@123\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.accessToken) pm.environment.set('accessToken', data.accessToken);",
                  "if (data.refreshToken) pm.environment.set('refreshToken', data.refreshToken);"
                ]
              }
            }
          ]
        },
        {
          "name": "Refresh Access Token",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/refresh"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.accessToken) pm.environment.set('accessToken', data.accessToken);"
                ]
              }
            }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/logout"
          }
        }
      ]
    },
    {
      "name": "Public",
      "item": [
        {
          "name": "List Jobs",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/jobs?keyword=engineer&location=india&remoteType=remote&page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "jobs"],
              "query": [
                { "key": "keyword", "value": "engineer" },
                { "key": "location", "value": "india" },
                { "key": "remoteType", "value": "remote" },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.items && data.items.length) pm.environment.set('jobId', data.items[0].id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Job By ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/jobs/{{jobId}}"
          }
        },
        {
          "name": "Get Company By ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/companies/{{companyId}}"
          }
        }
      ]
    },
    {
