# GEMINI_API_KEY: Required for Gemini AI API calls.
# Put your own key here in local development.
GEMINI_API_KEY=your_gemini_api_key_here

# APP_URL: The URL where this app is hosted.
APP_URL=http://localhost:3000

# Backend API URL for local development.
VITE_API_BASE_URL=http://localhost:4000

# Public site URL used for canonical links and sitemap hostname
VITE_SITE_URL=https://redresumes.com

# Optional: Add GA4 Measurement ID to enable analytics (example: G-XXXXXXX)
VITE_GA_MEASUREMENT_ID=

# Optional: Google Sign-In Web Client ID
VITE_GOOGLE_CLIENT_ID=your_google_web_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_ID=your_google_web_client_id.apps.googleusercontent.com
