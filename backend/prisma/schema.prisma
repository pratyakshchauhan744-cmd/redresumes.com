generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  candidate
  employer
  admin
}

enum RemoteType {
  onsite
  hybrid
  remote
}

enum EmploymentType {
  full_time
  part_time
  contract
  internship
  freelance
}

enum ExperienceLevel {
  entry
  mid
  senior
  lead
}

enum JobSourceType {
  api
  direct
}

enum ApplicationStatus {
  submitted
  reviewing
  shortlisted
  rejected
  hired
}

model User {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  passwordHash  String
  role          UserRole       @default(candidate)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  applications  Application[]
  savedJobs     SavedJob[]
  postedJobs    Job[]          @relation("EmployerJobs")
  companies     Company[]      @relation("EmployerCompany")
  refreshTokens RefreshToken[]
}

model Company {
  id          String   @id @default(cuid())
  name        String
  website     String?
  logoUrl     String?
  description String?
  location    String?
  ownerId     String?
  owner       User?    @relation("EmployerCompany", fields: [ownerId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  jobs        Job[]

  @@index([name])
}

model Job {
  id             String          @id @default(cuid())
  title          String
  description    String
  companyId      String
  company        Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  postedById     String?
  postedBy       User?           @relation("EmployerJobs", fields: [postedById], references: [id], onDelete: SetNull)
  city           String?
  state          String?
  country        String?
  remoteType     RemoteType      @default(onsite)
  employmentType EmploymentType  @default(full_time)
  experienceLevel ExperienceLevel @default(entry)
  salaryMin      Int?
  salaryMax      Int?
  currency       String?         @default("USD")
  sourceType     JobSourceType   @default(direct)
  externalId     String?
  applyUrl       String?
  postedAt       DateTime        @default(now())
  dedupeHash     String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  applications   Application[]
  savedByUsers   SavedJob[]

  @@unique([dedupeHash])
  @@index([title])
  @@index([city, state, country])
  @@index([companyId])
  @@index([postedById])
}

model Application {
  id        String            @id @default(cuid())
  userId    String
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId     String
  job       Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  resumeUrl String?
  status    ApplicationStatus @default(submitted)
  appliedAt DateTime          @default(now())
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@unique([userId, jobId])
  @@index([jobId])
}

model SavedJob {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, jobId])
  @@index([jobId])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model IngestionLog {
  id           String   @id @default(cuid())
  source       String
  fetchedCount Int      @default(0)
  insertedCount Int     @default(0)
  dedupedCount Int      @default(0)
  status       String
  createdAt    DateTime @default(now())
}
